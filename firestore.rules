rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} { allow read, write: if false; }
    
    function isSignedIn() { return request.auth != null; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    
    function isAdmin() { 
      return isSignedIn() && (
        request.auth.token.email == 'funilsites@gmail.com' ||
        request.auth.token.email == 'estudiokasar@gmail.com' ||
        request.auth.uid == 'pZ14BRaUndVhBGUH3iTXZMBLHm' ||
        request.auth.uid == 'pZ14BRaUndVhBGUH3iTXZMBLHmS2' ||
        request.auth.uid == 'bDFXkFV9YKPmVrroTqBJVvnhnNy1'
      ); 
    }

    match /cashback_signups/{signupId} {
      allow create: if !exists(/databases/$(database)/documents/cashback_signups/$(signupId));
      allow read, update, delete: if isAdmin();
    }

    match /polls/{pollId} {
      allow read: if true;
      allow write: if isAdmin() && isValidId(pollId);
    }

    match /vote_checks/{checkId} {
      allow create: if !exists(/databases/$(database)/documents/vote_checks/$(checkId)) && isValidId(checkId);
      allow read, update, delete: if isAdmin();
    }

    match /votes/{voteId} {
      allow read: if true;
      allow create: if true;
      allow update, delete: if isAdmin() && isValidId(voteId);
    }

    match /customers/{customerId} {
      allow read: if isAdmin();
      allow create: if (isAdmin() && isValidId(customerId)) || 
                       (isValidId(customerId) && incoming().pointsBalance == 0 && incoming().cashbackBalance == 0);
      allow update: if isAdmin() && isValidId(customerId);
      allow delete: if isAdmin() && isValidId(customerId);
    }
    
    match /transactions/{transactionId} {
      allow read: if isAdmin();
      allow create: if isAdmin() && isValidId(transactionId);
      allow update: if isAdmin() && isValidId(transactionId);
      allow delete: if isAdmin() && isValidId(transactionId);
    }

    match /settings/{docId} {
      allow read: if isAdmin();
      allow create: if isAdmin() && isValidId(docId);
      allow update: if isAdmin() && isValidId(docId);
      allow delete: if isAdmin() && isValidId(docId);
    }

    match /public_balances/{docId} {
      allow read: if true;
      allow create: if isAdmin() || (incoming().points == 0 && incoming().cashback == 0);
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }
  }
}
